# Garuda ignore rules

# OS generated files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editor and IDE state
.idea/
*.iml
.vscode/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Local environment and secrets
.env
.env.*
!.env.example
.secret
secrets/
keys/
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs and temp files
logs/
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Frontend / Vite / TypeScript
src/frontend/node_modules/
src/frontend/dist/
src/frontend/build/
src/frontend/.vite/
src/frontend/.vite-inspect/
src/frontend/vite.config.*.timestamp-*
src/frontend/vite.config.*.mjs
*.tsbuildinfo

# Package manager caches
.npm/
.pnpm-store/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Python
__pycache__/
*.py[cod]
*$py.class
env/
venv/
.venv/
.envrc
pip-wheel-metadata/
build/
dist/
*.egg-info/
.eggs/
.python-version
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.pytest_cache/
coverage/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.ipynb_checkpoints/

# Backend local artifacts
src/backend/.venv/
src/backend/.pytest_cache/
src/backend/.ruff_cache/
src/backend/htmlcov/

# SQLite and local application data
*.db
*.db-*
*.sqlite
*.sqlite3
*.sqlite3-*
data/
local-data/
research-data/
instance/

# Keep committed seed and template examples
!seed/
!seed/**
!templates/
!templates/**

# Build outputs, compiled files
*.class
*.o
*.pyc
*.pyo
*.pyd
*.dll
*.so
*.dylib
*.exe

# Test artifacts
test-results/
playwright-report/
blob-report/
coverage/
src/frontend/coverage/
src/backend/coverage/

# Reports and generated exports
reports/
exports/
*.bak

# Local runtime files
*.pid
*.seed
*.pid.lock

# End of file

